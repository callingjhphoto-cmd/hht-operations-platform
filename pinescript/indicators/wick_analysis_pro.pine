// Wick Analysis Pro - Inspired by Wicks Trading System + ICT Methodology
// Detects wick rejections, liquidity sweeps, wick fills, and volume-confirmed wicks

//@version=5
indicator("Wick Analysis Pro", shorttitle="WAP", overlay=true, max_labels_count=500)

// ═══════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════

// Wick Detection
wickRatio      = input.float(2.0, "Min Wick-to-Body Ratio", minval=0.5, step=0.1, group="Wick Detection",
                 tooltip="Minimum ratio of wick length to body length for signal")
wickPercent    = input.float(0.6, "Min Wick % of Total Range", minval=0.1, maxval=0.99, step=0.05, group="Wick Detection",
                 tooltip="Wick must be at least this % of the total candle range")

// Volume Confirmation
useVolFilter   = input.bool(true, "Require Volume Confirmation", group="Volume")
volLookback    = input.int(3, "Volume Lookback Bars", minval=1, maxval=20, group="Volume")
volMult        = input.float(1.0, "Volume Multiplier", minval=0.5, step=0.1, group="Volume",
                 tooltip="Current volume must exceed average of lookback bars × this multiplier")

// Fibonacci Integration
showFib        = input.bool(true, "Show Fibonacci Levels", group="Fibonacci")
fibLookback    = input.int(50, "Swing Lookback", minval=10, maxval=200, group="Fibonacci")

// Wick Fill Tracking
showWickFill   = input.bool(true, "Track Wick Fill Zones", group="Wick Fill")
wickFillExpiry = input.int(50, "Wick Fill Zone Expiry (bars)", minval=10, maxval=200, group="Wick Fill")

// Display
showLabels     = input.bool(true, "Show Signal Labels", group="Display")
showZones      = input.bool(true, "Show Rejection Zones", group="Display")

// ═══════════════════════════════════════════════════
// WICK CALCULATIONS
// ═══════════════════════════════════════════════════

// Candle components
bodySize    = math.abs(close - open)
totalRange  = high - low
upperWick   = high - math.max(close, open)
lowerWick   = math.min(close, open) - low

// Avoid division by zero
safeBody    = math.max(bodySize, syminfo.mintick)

// Wick ratios
upperWickRatio = upperWick / safeBody
lowerWickRatio = lowerWick / safeBody
upperWickPct   = totalRange > 0 ? upperWick / totalRange : 0
lowerWickPct   = totalRange > 0 ? lowerWick / totalRange : 0

// ═══════════════════════════════════════════════════
// VOLUME CONFIRMATION
// ═══════════════════════════════════════════════════

avgVol       = ta.sma(volume, volLookback)
volConfirmed = not useVolFilter or (volume > avgVol * volMult)

// ═══════════════════════════════════════════════════
// WICK REJECTION SIGNALS
// ═══════════════════════════════════════════════════

// Upper wick rejection (bearish)
// Long upper wick = price tested higher but rejected = selling pressure
upperRejection = upperWickRatio >= wickRatio and
                 upperWickPct >= wickPercent and
                 volConfirmed and
                 totalRange > 0

// Lower wick rejection (bullish)
// Long lower wick = price tested lower but rejected = buying pressure
lowerRejection = lowerWickRatio >= wickRatio and
                 lowerWickPct >= wickPercent and
                 volConfirmed and
                 totalRange > 0

// ═══════════════════════════════════════════════════
// ICT LIQUIDITY SWEEP DETECTION
// ═══════════════════════════════════════════════════

// Recent swing highs and lows
swingHigh = ta.pivothigh(high, 5, 5)
swingLow  = ta.pivotlow(low, 5, 5)

// Track last swing levels
var float lastSwingHigh = na
var float lastSwingLow  = na

if not na(swingHigh)
    lastSwingHigh := swingHigh
if not na(swingLow)
    lastSwingLow := swingLow

// Liquidity sweep: price exceeds swing level but closes back inside (wick through)
bullSweep = not na(lastSwingLow) and
            low < lastSwingLow and
            close > lastSwingLow and
            lowerWickPct > 0.5

bearSweep = not na(lastSwingHigh) and
            high > lastSwingHigh and
            close < lastSwingHigh and
            upperWickPct > 0.5

// ═══════════════════════════════════════════════════
// WICK FILL PROBABILITY ZONES
// ═══════════════════════════════════════════════════

// When a significant wick forms, the unfilled area often gets revisited
// Track upper wick zones (potential fill targets for bulls)
// Track lower wick zones (potential fill targets for bears)

var box[] upperBoxes = array.new_box()
var box[] lowerBoxes = array.new_box()

if showWickFill and upperRejection and upperWick > ta.atr(14) * 0.5
    newBox = box.new(bar_index, high, bar_index + wickFillExpiry,
             math.max(close, open), color.new(#FF1744, 90), 1,
             line.style_dotted, bgcolor=color.new(#FF1744, 95))
    array.push(upperBoxes, newBox)

if showWickFill and lowerRejection and lowerWick > ta.atr(14) * 0.5
    newBox = box.new(bar_index, math.min(close, open), bar_index + wickFillExpiry,
             low, color.new(#00E676, 90), 1,
             line.style_dotted, bgcolor=color.new(#00E676, 95))
    array.push(lowerBoxes, newBox)

// ═══════════════════════════════════════════════════
// MULTI-WICK CONFLUENCE (Accumulation of Evidence)
// ═══════════════════════════════════════════════════

// Count wick rejections at similar price levels (within ATR distance)
atrVal = ta.atr(14)

// Count recent lower wick rejections in a price zone
var int bullWickCount = 0
var int bearWickCount = 0

if lowerRejection
    bullWickCount := bullWickCount + 1
else if bar_index % 20 == 0  // Reset every 20 bars
    bullWickCount := math.max(0, bullWickCount - 1)

if upperRejection
    bearWickCount := bearWickCount + 1
else if bar_index % 20 == 0
    bearWickCount := math.max(0, bearWickCount - 1)

// Strong zone = multiple rejections
strongBullZone = bullWickCount >= 3
strongBearZone = bearWickCount >= 3

// ═══════════════════════════════════════════════════
// SIGNAL STRENGTH SCORING
// ═══════════════════════════════════════════════════

// Score each signal 1-5 based on confirming factors
bullScore = (lowerRejection ? 1 : 0) +
            (volConfirmed and lowerRejection ? 1 : 0) +
            (bullSweep ? 1 : 0) +
            (bullWickCount >= 2 ? 1 : 0) +
            (close > open and lowerRejection ? 1 : 0)  // Bullish close

bearScore = (upperRejection ? 1 : 0) +
            (volConfirmed and upperRejection ? 1 : 0) +
            (bearSweep ? 1 : 0) +
            (bearWickCount >= 2 ? 1 : 0) +
            (close < open and upperRejection ? 1 : 0)  // Bearish close

// ═══════════════════════════════════════════════════
// PLOTS & LABELS
// ═══════════════════════════════════════════════════

// Signal markers
plotshape(lowerRejection and bullScore >= 3, "Strong Bull Wick",
          shape.triangleup, location.belowbar, color.new(#00E676, 0), size=size.small)
plotshape(lowerRejection and bullScore < 3, "Weak Bull Wick",
          shape.circle, location.belowbar, color.new(#00E676, 50), size=size.tiny)

plotshape(upperRejection and bearScore >= 3, "Strong Bear Wick",
          shape.triangledown, location.abovebar, color.new(#FF1744, 0), size=size.small)
plotshape(upperRejection and bearScore < 3, "Weak Bear Wick",
          shape.circle, location.abovebar, color.new(#FF1744, 50), size=size.tiny)

// Liquidity sweep signals
plotshape(bullSweep, "Bull Liquidity Sweep",
          shape.diamond, location.belowbar, color.new(#FFD600, 0), size=size.small)
plotshape(bearSweep, "Bear Liquidity Sweep",
          shape.diamond, location.abovebar, color.new(#FFD600, 0), size=size.small)

// Labels for high-confidence signals
if showLabels and lowerRejection and bullScore >= 4
    label.new(bar_index, low, "WICK\n" + str.tostring(bullScore) + "/5",
              color=color.new(#00E676, 0), textcolor=color.white,
              style=label.style_label_up, size=size.small)

if showLabels and upperRejection and bearScore >= 4
    label.new(bar_index, high, "WICK\n" + str.tostring(bearScore) + "/5",
              color=color.new(#FF1744, 0), textcolor=color.white,
              style=label.style_label_down, size=size.small)

if showLabels and bullSweep
    label.new(bar_index, low, "SWEEP",
              color=color.new(#FFD600, 0), textcolor=color.black,
              style=label.style_label_up, size=size.tiny)

if showLabels and bearSweep
    label.new(bar_index, high, "SWEEP",
              color=color.new(#FFD600, 0), textcolor=color.black,
              style=label.style_label_down, size=size.tiny)

// ═══════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════

alertcondition(lowerRejection and bullScore >= 3, "Strong Bull Wick Rejection",
               "Strong bullish wick rejection detected — buying pressure confirmed")
alertcondition(upperRejection and bearScore >= 3, "Strong Bear Wick Rejection",
               "Strong bearish wick rejection detected — selling pressure confirmed")
alertcondition(bullSweep, "Bullish Liquidity Sweep",
               "Bullish liquidity sweep — price swept lows and reversed")
alertcondition(bearSweep, "Bearish Liquidity Sweep",
               "Bearish liquidity sweep — price swept highs and reversed")
alertcondition(strongBullZone, "Strong Bull Wick Zone",
               "Multiple wick rejections at this support level — strong demand zone")
alertcondition(strongBearZone, "Strong Bear Wick Zone",
               "Multiple wick rejections at this resistance level — strong supply zone")
