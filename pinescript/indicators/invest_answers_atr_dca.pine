// Invest Answers DCAS (Dollar Cost Average on Steroids) — v2 Corrected
// Based on exhaustive research of James Mullarney's actual methodology
//
// RESEARCH FINDINGS:
// - DCAS uses multiplier-based buy sizing (0.5x to 3.0x), NOT static zone levels
// - Signal logic: Above/Below a reference line + Green/Red state
//   - Above line + Green = "Nibble" (small buy, ~0.5-1.0x)
//   - Below line + Green = "Amplify" (larger buy, ~1.5-3.0x)
//   - Red (any position) = NO BUY
// - Requires daily timeframe and 2+ years of history
// - ATR = "Augmented Trading Range" (proprietary), approximated here
//   with adaptive volatility bands + trend cloud
// - Works across crypto, stocks, commodities, indices
//
// ACCURACY vs REAL: ~6/10 (improved from 4/10)
// We cannot replicate the proprietary "calculation engine" but this
// captures the core philosophy: buy more at deeper discounts, skip red periods

//@version=5
indicator("IA DCAS — Dollar Cost Average on Steroids", shorttitle="IA-DCAS", overlay=true)

// ═══════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════

// DCAS Core
dcaBudget    = input.float(100, "Weekly DCA Budget ($)", minval=1, group="DCAS Settings",
               tooltip="Your standard weekly buy amount. Multiplier adjusts this.")
dcaAggression = input.string("Balanced", "Strategy Style",
               options=["Conservative", "Balanced", "Aggressive"], group="DCAS Settings",
               tooltip="Conservative waits for deep discounts. Aggressive buys more often.")

// Augmented Trading Range (approximation of IA's proprietary ATR)
atrLength    = input.int(14, "Volatility Length", minval=1, group="Augmented Range")
rangeBasis   = input.int(50, "Range Basis MA", minval=10, group="Augmented Range")
rangeType    = input.string("EMA", "MA Type", options=["SMA", "EMA", "WMA"], group="Augmented Range")
innerMult    = input.float(1.5, "Inner Range Width", minval=0.5, step=0.1, group="Augmented Range")
outerMult    = input.float(2.5, "Outer Range Width", minval=0.5, step=0.1, group="Augmented Range")

// Trend Cloud (IA's ATR product includes a "trend cloud")
cloudFast    = input.int(21, "Cloud Fast MA", minval=1, group="Trend Cloud")
cloudSlow    = input.int(55, "Cloud Slow MA", minval=1, group="Trend Cloud")
showCloud    = input.bool(true, "Show Trend Cloud", group="Trend Cloud")

// Display
showTable    = input.bool(true, "Show DCAS Signal Table", group="Display")
showHistory  = input.bool(true, "Show Historical Signals", group="Display")

// ═══════════════════════════════════════════════════
// AUGMENTED TRADING RANGE (Approximation)
// ═══════════════════════════════════════════════════

// IA's "ATR" is NOT standard Average True Range — it's a proprietary range tool
// We approximate with adaptive volatility bands around a moving average basis
basis = switch rangeType
    "SMA" => ta.sma(close, rangeBasis)
    "EMA" => ta.ema(close, rangeBasis)
    "WMA" => ta.wma(close, rangeBasis)
    => ta.ema(close, rangeBasis)

atrVal = ta.atr(atrLength)

innerUp = basis + atrVal * innerMult
innerDn = basis - atrVal * innerMult
outerUp = basis + atrVal * outerMult
outerDn = basis - atrVal * outerMult

// ═══════════════════════════════════════════════════
// TREND CLOUD (Part of IA's ATR product)
// ═══════════════════════════════════════════════════

cloudFastMA = ta.ema(close, cloudFast)
cloudSlowMA = ta.ema(close, cloudSlow)
cloudBull   = cloudFastMA > cloudSlowMA
cloudBear   = cloudFastMA < cloudSlowMA

// ═══════════════════════════════════════════════════
// DCAS SIGNAL ENGINE
// ═══════════════════════════════════════════════════

// Reference line = basis (center of augmented range)
aboveLine = close >= basis
belowLine = close < basis

// Distance from basis as % of range (how deep the discount)
rangeWidth = outerUp - outerDn
distFromBasis = rangeWidth > 0 ? (basis - close) / rangeWidth * 100 : 0
distFromBasisUp = rangeWidth > 0 ? (close - basis) / rangeWidth * 100 : 0

// ATH (All-Time High) distance — key factor in DCAS per GitHub gist research
// The rhettre implementation uses distance from ATH for buy sizing
athPrice = ta.highest(high, 730)  // ~2 years of daily bars (730 trading days)
athDist  = athPrice > 0 ? (athPrice - close) / athPrice * 100 : 0

// Green/Red State Determination
// Green = favorable conditions for buying (trend supportive or oversold)
// Red = unfavorable (strong downtrend momentum, no buying)
//
// Approximation based on research:
// - Momentum turning positive after decline = Green
// - Strong downward momentum still accelerating = Red
rsiVal   = ta.rsi(close, 14)
rsiMA    = ta.ema(rsiVal, 5)
momTrend = ta.ema(close, 10) - ta.ema(close, 30)
momAccel = momTrend - momTrend[5]

// Green state: momentum stabilizing/turning OR RSI rising from oversold
greenState = momAccel > 0 or (rsiVal > rsiMA and rsiVal > rsiVal[3])
// Red state: momentum still accelerating downward
redState   = not greenState

// ═══════════════════════════════════════════════════
// MULTIPLIER CALCULATION (Core DCAS Innovation)
// ═══════════════════════════════════════════════════

// DCAS doesn't just say "buy" — it says "buy X times your normal amount"
// Multiplier ranges from 0 (no buy / red) to 3.0x (maximum conviction)
//
// Logic derived from research:
// - Red state: 0x (no buy regardless of position)
// - Above line + Green: 0.5x to 1.0x ("Nibble")
// - Below line + Green: 1.0x to 3.0x ("Amplify") scaled by depth of discount
// - Deeper discount from ATH = higher multiplier

// Aggression scaling
aggrScale = switch dcaAggression
    "Conservative" => 0.7
    "Balanced"     => 1.0
    "Aggressive"   => 1.3
    => 1.0

float dcaMultiplier = 0.0

if redState
    dcaMultiplier := 0.0
else if aboveLine and greenState
    // Nibble: 0.5x base, slightly more if just above line
    nibbleBase = 0.5
    nibbleBonus = math.max(0, 1.0 - distFromBasisUp / 25) * 0.5  // Less if far above
    dcaMultiplier := (nibbleBase + nibbleBonus) * aggrScale
else if belowLine and greenState
    // Amplify: 1.0x base + bonus for depth of discount
    // Scale by distance from basis (deeper = more)
    amplifyBase = 1.0
    // ATH distance bonus (further from ATH = buy more, per rhettre gist)
    athBonus = math.min(athDist / 50.0, 1.0)  // Cap at 1.0x from ATH distance
    // Range position bonus (deeper in range = buy more)
    depthBonus = math.min(distFromBasis / 30.0, 1.0)  // Cap at 1.0x from depth
    dcaMultiplier := math.min((amplifyBase + athBonus + depthBonus) * aggrScale, 3.0)

// Dollar amount to buy this period
dcaDollarAmount = dcaBudget * dcaMultiplier

// ═══════════════════════════════════════════════════
// SIGNAL CLASSIFICATION
// ═══════════════════════════════════════════════════

isBuySignal  = dcaMultiplier > 0
isNibble     = isBuySignal and aboveLine   // Above line + Green = Nibble
isAmplify    = isBuySignal and belowLine   // Below line + Green = Amplify
isNoBuy      = dcaMultiplier == 0          // Red state = Skip

// Signal strength for labels
sigStrength  = dcaMultiplier >= 2.5 ? "MAX"  :
               dcaMultiplier >= 1.5 ? "HIGH" :
               dcaMultiplier >= 1.0 ? "MED"  :
               dcaMultiplier >= 0.5 ? "LOW"  :
               "SKIP"

// New signals only (avoid label spam)
newNibble  = isNibble and (not isNibble[1] or (math.round(dcaMultiplier * 10) != math.round(dcaMultiplier[1] * 10)))
newAmplify = isAmplify and (not isAmplify[1] or dcaMultiplier > dcaMultiplier[1] + 0.3)
newNoBuy   = isNoBuy and not isNoBuy[1]

// ═══════════════════════════════════════════════════
// PLOTS — Augmented Trading Range
// ═══════════════════════════════════════════════════

pBasis = plot(basis, "Range Center", color.new(#FFFFFF, 30), linewidth=2)
pIU    = plot(innerUp, "Inner Upper", color.new(#FFD600, 60), linewidth=1)
pIL    = plot(innerDn, "Inner Lower", color.new(#FFD600, 60), linewidth=1)
pOU    = plot(outerUp, "Outer Upper", color.new(#FF6D00, 40), linewidth=1, style=plot.style_stepline)
pOL    = plot(outerDn, "Outer Lower", color.new(#FF6D00, 40), linewidth=1, style=plot.style_stepline)

fill(pIU, pIL, color.new(#FFD600, 93), title="Inner Range")
fill(pOU, pIU, color.new(#FF6D00, 95), title="Upper Extreme")
fill(pIL, pOL, color.new(#00E676, 95), title="Lower Zone (Amplify)")

// Trend Cloud
pCF = plot(showCloud ? cloudFastMA : na, "Cloud Fast", color.new(#00E676, 70), linewidth=1)
pCS = plot(showCloud ? cloudSlowMA : na, "Cloud Slow", color.new(#FF6D00, 70), linewidth=1)
fill(pCF, pCS,
     cloudBull ? color.new(#00E676, 88) : color.new(#FF1744, 88),
     title="Trend Cloud")

// ═══════════════════════════════════════════════════
// SIGNAL MARKERS
// ═══════════════════════════════════════════════════

// Green/Red state background
bgcolor(greenState ? color.new(#00E676, 96) : color.new(#FF1744, 96),
        title="DCAS State")

// Amplify signals (below line + green — the money makers)
plotshape(showHistory and newAmplify and dcaMultiplier >= 2.0, "Strong Amplify",
          shape.labelup, location.belowbar, color.new(#00C853, 0),
          text="AMP", textcolor=color.white, size=size.small)
plotshape(showHistory and newAmplify and dcaMultiplier < 2.0, "Mild Amplify",
          shape.triangleup, location.belowbar, color.new(#69F0AE, 0), size=size.tiny)

// Nibble signals (above line + green — small buys)
plotshape(showHistory and newNibble, "Nibble",
          shape.circle, location.belowbar, color.new(#B9F6CA, 0), size=size.tiny)

// No-buy transitions
plotshape(showHistory and newNoBuy, "No Buy",
          shape.xcross, location.abovebar, color.new(#FF1744, 50), size=size.tiny)

// ═══════════════════════════════════════════════════
// DCAS SIGNAL TABLE
// ═══════════════════════════════════════════════════

var table dcasTable = table.new(position.top_right, 2, 9,
                                bgcolor=color.new(#1E1E1E, 10),
                                border_width=1, border_color=color.new(#333333, 0))

if barstate.islast and showTable
    stateColor = greenState ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    multColor  = dcaMultiplier >= 2.0 ? color.new(#00C853, 0) :
                 dcaMultiplier >= 1.0 ? color.new(#69F0AE, 0) :
                 dcaMultiplier >= 0.5 ? color.new(#B9F6CA, 0) :
                 color.new(#FF1744, 0)

    table.cell(dcasTable, 0, 0, "DCAS ENGINE", text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))
    table.cell(dcasTable, 1, 0, "STATUS", text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))

    table.cell(dcasTable, 0, 1, "State", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 1, greenState ? "GREEN ●" : "RED ●",
               text_color=stateColor, text_size=size.tiny)

    table.cell(dcasTable, 0, 2, "Position", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 2, aboveLine ? "ABOVE LINE" : "BELOW LINE",
               text_color=aboveLine ? #FFD600 : #00E676, text_size=size.tiny)

    table.cell(dcasTable, 0, 3, "Signal", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 3, isAmplify ? "AMPLIFY ▲▲" : isNibble ? "NIBBLE ▲" : "NO BUY ✕",
               text_color=isAmplify ? #00C853 : isNibble ? #B9F6CA : #FF1744, text_size=size.tiny)

    table.cell(dcasTable, 0, 4, "Multiplier", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 4, str.tostring(math.round(dcaMultiplier, 1)) + "x",
               text_color=multColor, text_size=size.small)

    table.cell(dcasTable, 0, 5, "Buy Amount", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 5, "$" + str.tostring(math.round(dcaDollarAmount)),
               text_color=multColor, text_size=size.small)

    table.cell(dcasTable, 0, 6, "ATH Distance", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 6, str.tostring(math.round(athDist, 1)) + "%",
               text_color=athDist > 30 ? #00E676 : athDist > 10 ? #FFD600 : #FF1744, text_size=size.tiny)

    table.cell(dcasTable, 0, 7, "Trend Cloud", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 7, cloudBull ? "BULLISH" : "BEARISH",
               text_color=cloudBull ? #00E676 : #FF1744, text_size=size.tiny)

    table.cell(dcasTable, 0, 8, "Style", text_color=color.white, text_size=size.tiny)
    table.cell(dcasTable, 1, 8, dcaAggression, text_color=#BDBDBD, text_size=size.tiny)

// ═══════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════

alertcondition(newAmplify and dcaMultiplier >= 2.0, "Strong Amplify Signal",
               "DCAS AMPLIFY — Below line + Green state. Multiplier 2.0x+. Buy aggressively.")
alertcondition(newAmplify and dcaMultiplier < 2.0, "Mild Amplify Signal",
               "DCAS AMPLIFY — Below line + Green state. Moderate multiplier.")
alertcondition(newNibble, "Nibble Signal",
               "DCAS NIBBLE — Above line + Green state. Small buy.")
alertcondition(newNoBuy, "State Turned Red",
               "DCAS RED — No buying. Wait for green state to resume.")
alertcondition(greenState and not greenState[1], "Green State Activated",
               "DCAS state turned GREEN — buying window open")
alertcondition(redState and not redState[1], "Red State Activated",
               "DCAS state turned RED — stop buying, wait for green")
